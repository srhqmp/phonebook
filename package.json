{
  "name": "phonebook",
  "version": "1.0.0",
  "description": "phonebook app",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "build:ui": "rm -rf build && cd ../fullstackopen2/part2/phonebook/ && npm run build --prod && cp -r build ../../../phonebook/",
    "deploy": "git push heroku main",
    "deploy:full": "npm run build:ui && git add . && git commit -m uibuild && git push && npm run deploy",
    "logs:prod": "heroku logs --tail"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/srhqmp/phonebook.git"
  },
  "author": "Sarah",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/srhqmp/phonebook/issues"
  },
  "homepage": "https://github.com/srhqmp/phonebook#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^10.0.0",
    "express": "^4.17.1",
    "mongoose": "^5.12.13",
    "mongoose-unique-validator": "^2.0.3",
    "morgan": "^1.10.0",
    "morgan-body": "^2.6.5"
  },
  "devDependencies": {
    "nodemon": "^2.0.7"
  }
}
